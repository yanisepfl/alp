# HTTP/WS port the backend listens on
PORT=8787

# Toggle inbound/outbound frame logging (1 = on, 0 = off).
DEBUG_FRAMES=1

# B2 auth — SIWE → JWT.
# JWT_SECRET is required at boot (min 32 chars). Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-min-32-chars-openssl-rand-base64-48
JWT_TTL_SECONDS=86400

# SIWE message validation. Must match the FE origin that built the message.
EXPECTED_DOMAIN=localhost:3000
EXPECTED_URI=http://localhost:3000

# CORS allowed origin for /auth/* and /health.
CORS_ALLOW_ORIGIN=http://localhost:3000

# Dev-only: enables POST /auth/dev-token (mints a JWT for any address with
# no SIWE signature). Used by scripts/smoke.ts and pre-SIWE FE integration.
# MUST be 0 in production. Flip to 1 only for local dev / smoke runs.
AUTH_DEV_BYPASS=0

# B7 — agent ingest API. Required at boot, ≥32 chars (server exits otherwise).
# Generate with: openssl rand -base64 48
INGEST_SECRET=replace-me-min-32-chars-openssl-rand-base64-48

# B3 chain reads. Both required for vault chain mode; falls back to mock if either is missing.
# Base mainnet public RPC works for low-volume reads; substitute Alchemy/QuickNode for production.
BASE_RPC_URL=https://mainnet.base.org
# Set to the deployed ALPVault address. Use 'mock' or unset to keep the B1 random-walk ticker.
VAULT_ADDRESS=

# B3b vault event indexer.
# Optional: set to the block where ALPVault was deployed for accurate lifetime
# stats. Defaults to (head - 100000) which is ~2.3 days on Base.
VAULT_DEPLOY_BLOCK=
# eth_getLogs chunk size for backfill. Default 10000; raise on dedicated RPCs.
LOG_CHUNK_BLOCKS=10000

# B6 persistence. Single sqlite file, WAL mode. Parent dir is created at boot.
ALP_DB_PATH=./data/alp.sqlite
